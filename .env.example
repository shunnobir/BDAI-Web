# ── Copy this file to .env.local and fill in your values ─────────────

# Next.js
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PROJECT_NAME="Your Research Project Name"
NEXT_PUBLIC_PROJECT_ACRONYM="ACRONYM"

# Payload CMS
PAYLOAD_SECRET=your-very-long-random-secret-key-change-this

# PostgreSQL
DATABASE_URI=postgresql://research_user:research_pass@localhost:5432/research_db
# On Vercel, use a managed Postgres service (e.g. Neon, Supabase):
# DATABASE_URI=postgresql://user:pass@host:5432/db?sslmode=require

# Fuseki SPARQL Triplestore
# Internal URL — NEVER expose this directly; always proxy via /api/sparql
FUSEKI_URL=http://localhost:3030
FUSEKI_DATASET=research
FUSEKI_ADMIN_PASSWORD=fuseki_admin_pass
# Optional: Basic auth credentials for Fuseki (if enabled)
FUSEKI_USER=admin

# File Storage (local dev — switch to S3 for production)
PAYLOAD_STORAGE=local
# For S3/MinIO in production:
# PAYLOAD_STORAGE=s3
# S3_BUCKET=your-bucket-name
# S3_REGION=eu-west-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_ENDPOINT=https://your-minio-server.com  # for MinIO

# Email (Contact form)
SMTP_HOST=smtp.youruniversity.ac.uk
SMTP_PORT=587
SMTP_USER=your-email@university.ac.uk
SMTP_PASS=your-email-password
CONTACT_EMAIL=project-contact@university.ac.uk
