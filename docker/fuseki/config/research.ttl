# Apache Jena Fuseki — dataset configuration
# Place this file in: docker/fuseki/config/research.ttl

@prefix :        <#> .
@prefix fuseki:  <http://jena.apache.org/fuseki#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tdb2:    <http://jena.apache.org/2016/tdb#> .
@prefix ja:      <http://jena.hpl.hp.com/2005/11/Assembler#> .

# ── Service Definition ───────────────────────────────────────────────
:service_research rdf:type fuseki:Service ;
    rdfs:label                      "Research Project Knowledge Graph" ;
    fuseki:name                     "research" ;             # Dataset name → /research/sparql
    fuseki:serviceQuery             "sparql" ;
    fuseki:serviceQuery             "query" ;
    fuseki:serviceUpdate            "update" ;               # Disable this in production if read-only
    fuseki:serviceUpload            "upload" ;
    fuseki:serviceReadWriteGraphStore "data" ;
    fuseki:serviceReadGraphStore    "get" ;
    fuseki:dataset                  :dataset_research ;
    .

# ── TDB2 Persistent Dataset ──────────────────────────────────────────
:dataset_research rdf:type tdb2:DatasetTDB2 ;
    tdb2:location "/fuseki/databases/research" ;
    .
